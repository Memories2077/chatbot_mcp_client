# Environment variables for Ethereal Intelligence

# ============================================================================
# LLM Provider Configuration (At least ONE required)
# ============================================================================

# 1. Google Gemini API (Primary recommendation)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"
GEMINI_MODEL="gemini-2.5-flash"

# 2. Groq API (Alternative high-performance option)
# Get from: https://console.groq.com/keys
GROQ_API_KEY="your-groq-api-key"
GROQ_MODEL="llama-3.3-70b-versatile"

# 3. MetaClaw Proxy Integration (Brain architecture)
# MetaClaw acts as an intelligent proxy with skill injection capabilities.
# When enabled, ALL requests route through MetaClaw regardless of provider setting.
# Requires: METACLAW_BASE_URL (running MetaClaw instance) and METACLAW_API_KEY
METACLAW_ENABLED=false  # Set to "true" to enable MetaClaw routing
METACLAW_BASE_URL="http://host.docker.internal:30000/v1"
METACLAW_API_KEY="your-metaclaw-api-key"
# Optional: Override model name for MetaClaw (if it respects it)
METACLAW_MODEL="gemini-2.5-flash"

# ============================================================================
# Backend Configuration
# ============================================================================

# Port Configuration
# - For local development, use NEXT_PUBLIC_BACKEND_PORT.
# - For Docker, docker-compose will also use this value.
# - The frontend will run on port 9002.
NEXT_PUBLIC_BACKEND_PORT=8000

# Backend URL (Optional Override)
# - In Docker, this is set automatically. You don't need to uncomment it.
# - For local development, the app constructs the URL automatically from the port above.
# - You only need to set this for advanced cases (e.g., pointing to a remote backend).
# NEXT_PUBLIC_BACKEND_URL="http://localhost:8000"

# ============================================================================
# LangGraph Configuration (for MCP Server Generation)
# ============================================================================

# LangGraph API URL (where the agent service runs)
NEXT_PUBLIC_LANGGRAPH_API_URL="http://localhost:2024"
# or
LANGGRAPH_API_URL="http://localhost:2024"

# ============================================================================
# General LLM Settings
# ============================================================================

LLM_TEMPERATURE=0.0
LLM_TIMEOUT_MS=300000

# ============================================================================
# MCP Server Connection Settings
# ============================================================================

MCP_CONNECTION_TIMEOUT=10.0
MCP_INIT_TIMEOUT=10.0

# ============================================================================
# MongoDB Configuration (for Feedback Storage)
# ============================================================================

# MongoDB connection string
# - In Docker (with mcp-gen stack running): use the default "mongodb://mongodb:27017"
# - For local development (if running MongoDB locally): "mongodb://localhost:27017"
# - For custom setups, set your own connection string
MONGODB_URL="mongodb://mongodb:27017"

# MongoDB database name
# - Default: "docker" (used by mcp-gen stack)
# - You can use a separate database like "chatbot" to isolate feedback data
MONGODB_DB="docker"