# Environment variables for Ethereal Intelligence

# ============================================================================
# Browser/Public Configuration (safe to expose in the Next.js browser bundle)
# ============================================================================

# Browser-reachable FastAPI URL. Use localhost because the user's browser runs on
# the host, not inside the Docker network.
NEXT_PUBLIC_BACKEND_URL="http://localhost:8000"

# Deprecated compatibility fallback for older frontend configs. Prefer
# NEXT_PUBLIC_BACKEND_URL above and BACKEND_PORT below for backend runtime.
NEXT_PUBLIC_BACKEND_PORT=8000

# Optional only if the frontend intentionally calls mcp-gen directly. The current
# app proxies generated-server list and feedback through FastAPI, so this is not
# required for normal operation. If used, it must be browser-reachable.
# NEXT_PUBLIC_MCP_GEN_URL="http://localhost:8080"

# ============================================================================
# Backend/Container Configuration (do not use NEXT_PUBLIC_ prefixes here)
# ============================================================================

# FastAPI runtime port. docker-compose maps this to the host on the same port.
BACKEND_PORT=8000

# LangGraph agent service URL as seen by FastAPI.
# - Host-local backend development: http://localhost:2024
# - Docker backend on the shared stack network: http://agent-service:2024
LANGGRAPH_API_URL="http://localhost:2024"

# mcp-gen manager URL as seen by FastAPI for proxy routes.
# - Host-local backend development: http://localhost:8080
# - Docker backend on the shared mcp-network: http://docker-manager:8080
MCP_GEN_URL="http://localhost:8080"

# CORS origins allowed to call FastAPI from a browser.
ALLOWED_ORIGINS="http://localhost:9002"

# ============================================================================
# LLM Provider Configuration (at least ONE direct provider or MetaClaw required)
# ============================================================================

# 1. Google Gemini API (primary recommendation)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"
GEMINI_MODEL="gemini-2.5-flash"

# 2. Groq API (alternative high-performance option)
# Get from: https://console.groq.com/keys
GROQ_API_KEY="your-groq-api-key"
GROQ_MODEL="llama-3.3-70b-versatile"

# Default direct/fallback provider used when MetaClaw proxy mode is disabled or
# when MetaClaw delegates casual chat to a direct provider.
LLM_PROVIDER="gemini"

# ============================================================================
# MetaClaw Proxy Integration (Brain architecture)
# ============================================================================

# MetaClaw acts as an intelligent proxy with skill injection capabilities.
# When enabled, backend chat requests route through MetaClaw regardless of the
# frontend provider selection. The frontend provider/model selection remains for
# direct mode or fallback semantics.
METACLAW_ENABLED=false
METACLAW_BASE_URL="http://host.docker.internal:30000/v1"
METACLAW_API_KEY="your-metaclaw-api-key"
METACLAW_MODEL="qwen/qwen3-next-80b-a3b-instruct"
METACLAW_TOP_P=0.5
METACLAW_MAX_TOKENS=100000

# ============================================================================
# General LLM Settings
# ============================================================================

LLM_TEMPERATURE=0.0
LLM_TIMEOUT_MS=300000

# ============================================================================
# MCP Server Connection Settings
# ============================================================================

MCP_CONNECTION_TIMEOUT=10.0
MCP_INIT_TIMEOUT=10.0
MCP_CONNECTION_RETRIES=3
MCP_RETRY_DELAY=2.0

# ============================================================================
# MongoDB Configuration (for feedback/history integrations)
# ============================================================================

# MongoDB connection string as seen by FastAPI.
# - Docker backend on the shared mcp-network: mongodb://mongodb:27017
# - Host-local development with local MongoDB: mongodb://localhost:27017
MONGODB_URL="mongodb://mongodb:27017"
MONGODB_DB="docker"
