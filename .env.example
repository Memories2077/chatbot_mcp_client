# Environment variables for Gemini InsightLink

# 1. Gemini API Key (Required for both local and Docker)
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# 2. Groq API Key (Experimental)
GROQ_API_KEY="your-groq-api-key"

# 2. Port Configuration
# - For local development, use NEXT_PUBLIC_BACKEND_PORT.
# - For Docker, docker-compose will also use this value.
# - The frontend will run on port 9002.
NEXT_PUBLIC_BACKEND_PORT=8000

# 3. Backend URL (Optional Override)
# - In Docker, this is set automatically. You don't need to uncomment it.
# - For local development, the app constructs the URL automatically from the port above.
# - You only need to set this for advanced cases (e.g., pointing to a remote backend).
# NEXT_PUBLIC_BACKEND_URL="http://localhost:8000"