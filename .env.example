# Gemini API Key - Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Backend Port Configuration
# Port for backend service (both container and host will use this port)
# Container listens on: 0.0.0.0:BACKEND_PORT
# Host access: http://localhost:BACKEND_PORT
# Docker network access (from frontend): http://backend:BACKEND_PORT
# Examples: 8000, 8001, 9003, 3001, etc.
BACKEND_PORT=8000

# (Optional) Override the frontend API URL directly.
# If not specified, the compose file will set NEXT_PUBLIC_BACKEND_URL
# automatically to http://backend:${BACKEND_PORT} when you run Docker.
# In a local non‑docker environment you may want to explicitly specify
# e.g. NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
#NEXT_PUBLIC_BACKEND_URL=http://backend:${BACKEND_PORT}
